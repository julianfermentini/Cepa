# ============================================================
# Cepa — Variables de entorno
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
# Local:    postgresql://cepa:password@postgres:5432/cepa_dev
# Supabase: postgresql://postgres.<ref>:<pass>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://cepa:password@postgres:5432/cepa_dev

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=cambiar_en_produccion_minimo_32_chars
JWT_EXPIRY_HOURS=24

# ── Storage (S3 / MinIO) ────────────────────────────────────
S3_ENDPOINT=http://minio:9000/
S3_BUCKET=cepa-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── AI sidecar (mockeado por ahora) ─────────────────────────
AI_SIDECAR_URL=ai-sidecar:50051
OPENAI_API_KEY=

# ── QR público ──────────────────────────────────────────────
# Producción: https://<tu-dominio-vercel>.vercel.app/wine
QR_BASE_URL=http://192.168.1.39:3000/wine

# ── Server ──────────────────────────────────────────────────
PORT=8080
ENV=development
